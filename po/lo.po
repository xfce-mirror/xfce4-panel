#: ../panel/main.c:423
msgid "Failed to show the add new items dialog"
msgstr "ບໍ່ສາມາດສະແດງໜ້າຕ່າງເພີ່ມລາຍການໃໝ່"

#: ../panel/main.c:425
msgid "Failed to save the panel configuration"
msgstr "ບໍ່ສາມາດບັນທຶກການຕັ້ງຄ່າແຖບ"

#: ../panel/main.c:427
msgid "Failed to add a plugin to the panel"
msgstr "ບໍ່ສາມາດເພີ່ມປລັກອິນໃສ່ແຖບ"

#: ../panel/main.c:429
msgid "Failed to restart the panel"
msgstr "ບໍ່ສາມາດເລີ່ມແຖບໃໝ່"

#: ../panel/main.c:431
msgid "Failed to quit the panel"
msgstr "ບໍ່ສາມາດອອກຈາກແຖບ"

#: ../panel/main.c:433
msgid "Failed to send D-Bus message"
msgstr "ບໍ່ສາມາດສົ່ງຂໍ້ຄວາມ D-Bus"

#: ../panel/main.c:443
msgid "Execute"
msgstr "ປະຕິບັດການ"

#: ../panel/main.c:444
msgid ""
"Do you want to start the panel? If you do, make sure you save the session on"
" logout, so the panel is automatically started the next time you login."
msgstr ""
"ທ່ານຕ້ອງການເລີ່ມແຖບເຄື່ອງມືບໍ່? ຫາກຕ້ອງການ, "
"ກະລຸນາແນ່ໃຈວ່າໄດ້ບັນທຶກເຊດຊັນຕອນອອກຈາກລະບົບ "
"ເພື່ອໃຫ້ແຖບເລີ່ມເຮັດວຽກໂດຍອັດຕະໂນມັດໃນຄັ້ງຕໍ່ໄປທີ່ທ່ານເຂົ້າລະບົບ."

#: ../panel/main.c:447 ../panel/main.c:461
#, c-format
msgid "No running instance of %s was found"
msgstr "ບໍ່ພົບຕົວເຄື່ອງທີ່ກຳລັງເຮັດວຽກຂອງ %s"

#: ../panel/panel-application.c:220
msgid "Failed to launch the migration application"
msgstr "ບໍ່ສາມາດເລີ່ມແອັບພລິເຄຊັນການເຄື່ອນຍ້າຍ (migration)"

#: ../panel/panel-application.c:1012
msgid "Create _Launcher"
msgstr "ສ້າງຕົວເລີ່ມ(_L)"

#: ../panel/panel-application.c:1013
msgid ""
"This will create a new launcher plugin on the panel and inserts the dropped "
"files as menu items."
msgstr ""
"ນີ້ຈະສ້າງປລັກອິນຕົວເລີ່ມໃໝ່ເທິງແຖບ ແລະ ແຊກໄຟລ໌ທີ່ລາກມາວາງໃຫ້ເປັນລາຍການເມນູ."

