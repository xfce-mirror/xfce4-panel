msgid ""
"Invalid plugin event syntax specified. Use PLUGIN-NAME:NAME[:TYPE:VALUE]."
msgstr "ໄວຍາກອນເຫດການປລັກອິນບໍ່ຖືກຕ້ອງ. ກະລຸນາໃຊ້ ຊື່ປລັກອິນ:ຊື່[:ປະເພດ:ຄ່າ]."

#: ../panel/panel-dbus-client.c:248
#, c-format
msgid ""
"Invalid hint type \"%s\". Valid types are bool, double, int, string and "
"uint."
msgstr ""
"ປະເພດ hint \"%s\" ບໍ່ຖືກຕ້ອງ. ປະເພດທີ່ໃຊ້ໄດ້ຄື bool, double, int, string ແລະ"
" uint."

