#: common/resources/panel-preferences-dialog.glade:413
msgid "Select this option to extend the panel over multiple monitors."
msgstr "ເລືອກຕົວເລືອກນີ້ເພື່ອຂະຫຍາຍແຖບໃຫ້ກວມເອົາຫຼາຍຈໍພາບ."

#: common/resources/panel-preferences-dialog.glade:426
msgid "_Lock panel"
msgstr "ລັອກແຖບ(_L)"

#: common/resources/panel-preferences-dialog.glade:430
msgid ""
"Select this option to hide the handles of the panel and lock its position."
msgstr "ເລືອກຕົວເລືອກນີ້ເພື່ອຊ່ອນບ່ອນຈັບຂອງແຖບ ແລະ ລັອກຕຳແໜ່ງຂອງມັນ."

