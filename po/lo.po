#, c-format
msgid "Create new launcher from %d desktop file"
msgid_plural "Create new launcher from %d desktop files"
msgstr[0] "ສ້າງຕົວເລີ່ມໃໝ່ຈາກໄຟລ໌ເດັສທັອບ %d ໄຟລ໌"

#: ../panel/panel-application.c:1772
msgid "Quit"
msgstr "ອອກ"

#: ../panel/panel-application.c:1773
msgid ""
"You have started X without session manager. Clicking Quit will close the X "
"server."
msgstr "ທ່ານໄດ້ເລີ່ມ X ໂດຍບໍ່ມີຕົວຈັດການເຊດຊັນ. ການຄລິກ 'ອອກ' ຈະປິດເຊີບເວີ X."

#: ../panel/panel-application.c:1774
msgid "Are you sure you want to quit the panel?"
msgstr "ທ່ານແນ່ໃຈບໍ່ວ່າຕ້ອງການອອກຈາກແຖບ?"

